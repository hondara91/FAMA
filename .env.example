# .env.example - Solo necesario si ejecutas la app FUERA de Docker.
# Con Docker, las variables ya vienen definidas en docker-compose.yml.

SECRET_KEY=cambia-esta-clave-en-produccion

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=1

# En Docker usar el nombre del servicio: mongodb://mongo:27017/
# En local usar: mongodb://localhost:27017/
MONGO_URI=mongodb://mongo:27017/
MONGO_DB_NAME=fama_db
